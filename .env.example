# Configuration locale — copier en `.env` et renseigner.
# Le tableau de bord (npm run serve -> /dashboard) lit Supabase avec la cle
# service_role, qui contourne la RLS. NE JAMAIS exposer cette cle cote navigateur.

# URL du projet Supabase, ex. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Cle service_role (Project Settings > API > service_role). Secrete.
SUPABASE_SERVICE_ROLE_KEY=

# Cle anon / publishable (Project Settings > API). Utilisee cote SERVEUR par les
# routes /api/auth/* (connexion, inscription). Le navigateur ne la voit jamais.
SUPABASE_ANON_KEY=

# Port du serveur local (optionnel, defaut 3000)
# PORT=3000
